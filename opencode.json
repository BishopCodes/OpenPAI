{
  "$schema": "https://opencode.ai/config.schema.json",

  // ─── Environment ───
  "env": {
    "PAI_DIR": "~/.config/openpai",
    "PROJECTS_DIR": "~/Projects",
    "PAI_CONFIG_DIR": "~/.config/openpai",
    "AGENT_TEAMS": "1"
  },

  // ─── Permissions ───
  "permission": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch",
      "NotebookRead",
      "NotebookEdit",
      "TodoWrite",
      "Task",
      "mcp__*"
    ],
    "deny": [],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(chmod -R 777*)",
      "Bash(> /dev/*)",
      "Write(~/.config/openpai/opencode.json)",
      "Edit(~/.config/openpai/opencode.json)",
      "Read(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.aws/*)"
    ]
  },

  // ─── Context & Instructions ───
  "instructions": [
    "AGENTS.md",
    "PAI/CONTEXT_ROUTING.md",
    "PAI/AISTEERINGRULES.md",
    "PAI/USER/AISTEERINGRULES.md",
    "PAI/USER/PROJECTS/PROJECTS.md"
  ],

  // ─── Plugins ───
  "plugin": [
    ".opencode/plugins/security-validator.ts",
    ".opencode/plugins/load-context.ts",
    ".opencode/plugins/voice-completion.ts",
    ".opencode/plugins/rating-capture.ts",
    ".opencode/plugins/session-manager.ts",
    ".opencode/plugins/skill-guard.ts",
    ".opencode/plugins/tui-hooks.ts",
    ".opencode/plugins/doc-integrity.ts",
    ".opencode/plugins/session-cache.ts",
    ".opencode/plugins/learning-hooks.ts"
  ],

  // ─── MCP Servers ───
  "mcp": {
    "cloudflare": {
      "type": "local",
      "command": ["npx", "@anthropic-ai/cloudflare-mcp-server"],
      "environment": {}
    }
  },

  // ─── Identity ───
  "openpai": {
    "version": "1.0.0",
    "repoUrl": "https://github.com/your-user/openpai",
    "algorithmVersion": "3.7.0",
    "assistant": {
      "name": "DA",
      "personality": {
        "enthusiasm": 60,
        "energy": 75,
        "expressiveness": 65,
        "resilience": 85,
        "composure": 70,
        "optimism": 75,
        "warmth": 70,
        "formality": 30,
        "directness": 80,
        "precision": 95,
        "curiosity": 90,
        "playfulness": 45
      },
      "voice": {
        "provider": "kokoro",
        "model": "kokoro-82m",
        "voiceId": "af_heart",
        "speed": 1.0
      }
    },
    "principal": {
      "name": "User",
      "timezone": "America/Los_Angeles"
    },
    "notifications": {
      "ntfy": {
        "enabled": false,
        "topic": "",
        "server": "https://ntfy.sh"
      },
      "discord": {
        "enabled": false,
        "webhookUrl": ""
      }
    },
    "counts": {
      "skills": 21,
      "workflows": 338,
      "hooks": 21,
      "signals": 0,
      "sessions": 0
    }
  }
}
