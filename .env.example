# ─── OpenPAI Configuration ───
# Your digital assistant's name
DA=DA

# Your timezone
TIME_ZONE=America/Los_Angeles

# PAI data directory (default: ~/.config/openpai)
# PAI_DIR=~/.config/openpai

# ─── Voice (Kokoro 82M - Local, No API Key Needed) ───
# Voice is local by default via Kokoro 82M. No keys required.
# To use edge-tts as alternative: VOICE_PROVIDER=edge-tts

# ─── Notifications (Optional) ───
# NTFY_TOPIC=your-topic
# NTFY_SERVER=https://ntfy.sh
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── MCP Servers (Optional) ───
# Add API keys for any MCP servers you configure in opencode.json

# ─── Pack-Specific Keys ───
# Skills/packs that need API access will document their keys here.
# All packs read from this single .env file.
